---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const B = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "") + "/";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const AUDIENCE_LABELS: Record<string, string> = {
  hobbyists: "Hobbyists",
  businesses: "Businesses",
  "hosting-providers": "Hosting Providers",
  enterprises: "Enterprises",
};
---

<Layout title="Blog" description="Guides, comparisons, and tutorials for game server management with Catalyst. For hobbyists, hosting providers, and enterprises.">

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach((el) => observer.observe(el));
  </script>

  <div class="max-w-4xl mx-auto px-4 sm:px-8 py-16 sm:py-20">
    <div data-reveal>
      <h1 class="font-display font-bold text-foreground tracking-tight" style="font-size: clamp(2rem, 5vw, 3.5rem);">
        Blog
      </h1>
      <p class="mt-3 text-base sm:text-lg text-zinc-400 leading-relaxed max-w-lg">
        Guides, comparisons, and deep dives for everyone running game servers — from hobbyists to hosting providers to enterprises.
      </p>
    </div>

    <div class="mt-12 space-y-4" data-reveal-stagger>
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });

        return (
          <a
            href={`/blog/${post.id}/`}
            class="group block rounded-xl border border-zinc-800/60 bg-surface-1 p-5 sm:p-6 transition-all duration-200 hover:border-zinc-700 hover:bg-surface-2"
          >
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {post.data.audience?.map((a) => (
                <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[11px] font-medium text-primary">
                  {AUDIENCE_LABELS[a] || a}
                </span>
              ))}
              <time datetime={post.data.pubDate.toISOString()} class="text-xs text-zinc-600">
                {formattedDate}
              </time>
            </div>
            <h2 class="font-display text-lg sm:text-xl font-semibold text-foreground group-hover:text-primary transition-colors leading-tight">
              {post.data.title}
            </h2>
            <p class="mt-2 text-sm text-zinc-500 leading-relaxed line-clamp-2">
              {post.data.description}
            </p>
          </a>
        );
      })}
    </div>

    {posts.length === 0 && (
      <div class="mt-12 text-center text-zinc-500">
        <p>Coming soon — stay tuned for guides, comparisons, and tutorials.</p>
      </div>
    )}
  </div>
</Layout>
