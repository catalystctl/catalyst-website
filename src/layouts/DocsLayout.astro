---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'docs'>;
  entries: CollectionEntry<'docs'>[];
}

const { entry, entries } = Astro.props;

// ── Build sidebar tree ──
interface SidebarItem {
  title: string;
  slug: string;
  order: number;
  description?: string;
}

interface SidebarGroup {
  label: string;
  slug: string;
  icon: string;
  items: SidebarItem[];
}

const groups = new Map<string, SidebarGroup>();

for (const e of entries) {
  const parts = e.id.split('/');
  let group: SidebarGroup;

  if (parts.length >= 2) {
    const groupSlug = parts.slice(0, -1).join('/');
    const groupLabel = parts.slice(0, -1).map(p => p.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())).join(' / ');
    if (!groups.has(groupSlug)) {
      groups.set(groupSlug, { label: groupLabel, slug: groupSlug, icon: '', items: [] });
    }
    group = groups.get(groupSlug)!;
  } else {
    const groupSlug = '_root';
    if (!groups.has(groupSlug)) {
      groups.set(groupSlug, { label: 'Overview', slug: '', icon: '', items: [] });
    }
    group = groups.get(groupSlug)!;
  }

  group.items.push({
    title: e.data.title,
    slug: e.id,
    order: e.data.order,
    description: e.data.description,
  });
}

const sidebar = Array.from(groups.values())
  .sort((a, b) => {
    if (a.slug === '_root') return -1;
    if (b.slug === '_root') return 1;
    return a.slug.localeCompare(b.slug);
  })
  .map(g => ({
    ...g,
    items: g.items.sort((a, b) => a.order - b.order),
  }));

const currentSlug = entry.id;

// ── Prev/next ──
const sortedEntries = entries
  .map(e => ({ id: e.id, title: e.data.title, group: e.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join('/') }))
  .sort((a, b) => a.id.localeCompare(b.id));
const currentIndex = sortedEntries.findIndex(e => e.id === currentSlug);
const prev = currentIndex > 0 ? sortedEntries[currentIndex - 1] : null;
const next = currentIndex < sortedEntries.length - 1 ? sortedEntries[currentIndex + 1] : null;

const { Content } = await render(entry);

// ── Table of contents (extracted from headings) ──
// We'll build this client-side with a script
---

<Layout title={entry.data.title} description={entry.data.description || `${entry.data.title} — Catalyst Documentation`} type="article">

  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-14 left-0 right-0 z-40 h-[2px] bg-transparent">
    <div class="h-full bg-gradient-to-r from-primary via-primary-400 to-emerald-400 origin-left scale-x-0 transition-transform" id="progress-bar"></div>
  </div>

  <div class="relative flex min-h-[calc(100vh-3.5rem)]">

    <!-- ═══════════════════════════════════════════════════════
         SIDEBAR — Desktop
         ═══════════════════════════════════════════════════════ -->
    <aside class="hidden lg:flex flex-col w-[280px] shrink-0 border-r border-zinc-800/60 bg-zinc-950/50 backdrop-blur-sm sticky top-14 h-[calc(100vh-3.5rem)] overflow-hidden">
      <!-- Sidebar header -->
      <div class="px-5 pt-5 pb-3">
        <a href="/docs/" class="group flex items-center gap-2.5 text-zinc-300 hover:text-foreground transition-colors">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-primary/10 ring-1 ring-primary/20">
            <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div>
            <span class="text-sm font-display font-semibold">Docs</span>
            <span class="block text-[10px] font-mono text-zinc-600 tracking-wider">{entries.length} pages</span>
          </div>
        </a>
      </div>

      <!-- Search hint -->
      <div class="px-5 pb-3">
        <div class="flex items-center gap-2 rounded-lg border border-zinc-800/60 bg-zinc-900/40 px-3 py-1.5 text-xs text-zinc-600">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <span>Search docs...</span>
          <kbd class="ml-auto inline-flex items-center rounded border border-zinc-700/50 bg-zinc-800/50 px-1.5 py-0.5 font-mono text-[10px] text-zinc-500">⌘K</kbd>
        </div>
      </div>

      <!-- Nav groups -->
      <nav class="flex-1 overflow-y-auto px-3 pb-6" aria-label="Documentation navigation">
        {sidebar.map((group) => (
          <div class="mb-4">
            <!-- Group label -->
            <button class="flex items-center gap-2 w-full px-2 py-1.5 text-[10px] font-semibold uppercase tracking-[0.15em] text-zinc-500 hover:text-zinc-400 transition-colors">
              {group.label}
              <span class="ml-auto text-[9px] font-mono text-zinc-700">{group.items.length}</span>
            </button>

            <!-- Group items -->
            <div class="space-y-px">
              {group.items.map((item) => {
                const href = `/docs/${item.slug}/`;
                const active = item.slug === currentSlug;
                return (
                  <a
                    href={href}
                    class:list={[
                      "relative flex items-center gap-2.5 rounded-lg px-2.5 py-[7px] text-[13px] leading-snug transition-all duration-150",
                      active
                        ? "text-foreground bg-zinc-800/70 font-medium"
                        : "text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/30",
                    ]}
                  >
                    <!-- Active indicator bar -->
                    {active && (
                      <span class="absolute left-0 top-1/2 -translate-y-1/2 h-4 w-[3px] rounded-full bg-primary shadow-[0_0_8px_hsl(var(--primary))]" />
                    )}
                    <span class="truncate">{item.title}</span>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </nav>

      <!-- Sidebar footer -->
      <div class="border-t border-zinc-800/40 px-5 py-3">
        <a
          href="https://github.com/catalystctl/catalyst-website"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-[11px] text-zinc-600 hover:text-zinc-400 transition-colors"
        >
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          Edit this page
        </a>
      </div>
    </aside>

    <!-- ═══════════════════════════════════════════════════════
         MOBILE DRAWER
         ═══════════════════════════════════════════════════════ -->
    <div id="mobile-drawer" class="lg:hidden fixed inset-0 z-50 pointer-events-none">
      <!-- Backdrop -->
      <div id="drawer-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm opacity-0 transition-opacity duration-300 pointer-events-none"></div>
      <!-- Panel -->
      <aside id="drawer-panel" class="absolute left-0 top-0 bottom-0 w-[300px] bg-zinc-950 border-r border-zinc-800 transform -translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] overflow-y-auto">
        <div class="flex items-center justify-between px-5 h-14 border-b border-zinc-800">
          <span class="text-sm font-display font-semibold text-zinc-200">Docs</span>
          <button id="drawer-close" class="flex h-8 w-8 items-center justify-center rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition-all" aria-label="Close navigation">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="px-3 py-4 space-y-4" aria-label="Documentation navigation (mobile)">
          {sidebar.map((group) => (
            <div>
              <span class="block px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-zinc-500">{group.label}</span>
              <div class="space-y-px mt-1">
                {group.items.map((item) => {
                  const href = `/docs/${item.slug}/`;
                  const active = item.slug === currentSlug;
                  return (
                    <a href={href} class:list={[
                      "relative flex items-center gap-2.5 rounded-lg px-2.5 py-[7px] text-[13px] transition-all",
                      active ? "text-foreground bg-zinc-800/70 font-medium" : "text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/30",
                    ]}>
                      {active && <span class="absolute left-0 top-1/2 -translate-y-1/2 h-4 w-[3px] rounded-full bg-primary" />}
                      {item.title}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </nav>
      </aside>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         CONTENT AREA
         ═══════════════════════════════════════════════════════ -->
    <div class="flex-1 min-w-0 flex">
      <!-- Main article -->
      <div class="flex-1 min-w-0">
        <div class="max-w-[720px] mx-auto px-6 sm:px-10 py-10">

          <!-- Mobile breadcrumb bar -->
          <div class="lg:hidden flex items-center gap-3 mb-8">
            <button id="mobile-menu-btn" class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-800 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/50 transition-all" aria-label="Open navigation">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
            </button>
            <nav class="flex items-center gap-1.5 text-xs text-zinc-600" aria-label="Breadcrumb">
              <a href="/docs/" class="hover:text-zinc-400 transition-colors">Docs</a>
              {entry.id.includes('/') && (
                <>
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                  <span class="text-zinc-500">{entry.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join(' / ')}</span>
                </>
              )}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
              <span class="text-zinc-400">{entry.data.title}</span>
            </nav>
          </div>

          <!-- Page header -->
          <header class="mb-12">
            <div class="flex items-center gap-2 mb-4">
              {entry.id.includes('/') && entry.id.split('/').slice(0, -1).map(part => (
                <span class="inline-flex items-center rounded-full border border-zinc-800 bg-zinc-900/50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500">
                  {part.replace(/-/g, ' ')}
                </span>
              ))}
            </div>
            <h1 class="font-display text-4xl sm:text-[2.75rem] font-bold text-zinc-50 leading-[1.15] tracking-tight">{entry.data.title}</h1>
            {entry.data.description && (
              <p class="mt-4 text-base sm:text-lg text-zinc-400 leading-relaxed max-w-[560px]">{entry.data.description}</p>
            )}
          </header>

          <!-- Markdown content -->
          <article class="doc prose-animate">
            <Content />
          </article>

          <!-- Prev / Next -->
          {(prev || next) && (
            <footer class="mt-20 pt-8 border-t border-zinc-800/60">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {prev && (
                  <a href={`/docs/${prev.id}/`} class="group flex flex-col gap-1 rounded-xl border border-zinc-800/60 bg-zinc-900/20 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-800/30">
                    <span class="flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-600">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                      Previous
                    </span>
                    <span class="text-sm font-medium text-zinc-300 group-hover:text-primary transition-colors">{prev.title}</span>
                    {prev.group && <span class="text-[10px] font-mono text-zinc-700">{prev.group}</span>}
                  </a>
                )}
                {next && (
                  <a href={`/docs/${next.id}/`} class:list={[
                    "group flex flex-col gap-1 rounded-xl border border-zinc-800/60 bg-zinc-900/20 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-800/30 text-right",
                    !prev && "sm:col-start-2",
                  ]}>
                    <span class="flex items-center justify-end gap-1.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-600">
                      Next
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                    </span>
                    <span class="text-sm font-medium text-zinc-300 group-hover:text-primary transition-colors">{next.title}</span>
                    {next.group && <span class="text-[10px] font-mono text-zinc-700">{next.group}</span>}
                  </a>
                )}
              </div>
            </footer>
          )}

          <!-- Bottom spacer -->
          <div class="h-24"></div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════
           TABLE OF CONTENTS — Desktop right rail
           ═══════════════════════════════════════════════════════ -->
      <aside id="toc-rail" class="hidden xl:block w-[200px] shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto">
        <div class="py-10 pr-4 pl-2">
          <span class="block text-[10px] font-semibold uppercase tracking-[0.15em] text-zinc-600 mb-4 px-2">On this page</span>
          <nav id="toc-links" class="space-y-px" aria-label="Table of contents">
            <!-- Populated by client script -->
          </nav>
        </div>
      </aside>
    </div>
  </div>

  <script>
    // ── Reading progress ──
    const progressBar = document.getElementById('progress-bar');
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      if (progressBar) {
        progressBar.style.transform = `scaleX(${Math.min(progress, 1)})`;
      }
    }, { passive: true });

    // ── Table of contents ──
    const article = document.querySelector('article.doc');
    const tocLinks = document.getElementById('toc-links');
    const headings = article?.querySelectorAll('h2, h3') || [];

    if (headings.length > 0 && tocLinks) {
      headings.forEach((heading, i) => {
        heading.id = heading.id || `heading-${i}`;
        const link = document.createElement('a');
        link.href = `#${heading.id}`;
        link.className = 'block px-2 py-1 text-[12px] leading-snug text-zinc-600 hover:text-zinc-300 transition-colors truncate';
        link.textContent = heading.textContent || '';

        // Indent h3
        if (heading.tagName === 'H3') {
          link.classList.add('pl-5');
          link.style.fontSize = '11px';
        }

        link.addEventListener('click', (e) => {
          e.preventDefault();
          heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        tocLinks.appendChild(link);
      });

      // Highlight active heading on scroll
      const tocAnchors = tocLinks.querySelectorAll('a');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocAnchors.forEach(a => {
              const isCurrent = a.getAttribute('href') === `#${id}`;
              a.classList.toggle('!text-primary', isCurrent);
              a.classList.toggle('!font-medium', isCurrent);
              a.classList.toggle('text-zinc-600', !isCurrent);
            });
          }
        });
      }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

      headings.forEach(h => observer.observe(h));
    } else if (tocLinks) {
      // Hide TOC rail if no headings
      const tocRail = document.getElementById('toc-rail');
      if (tocRail) tocRail.style.display = 'none';
    }

    // ── Mobile drawer ──
    const menuBtn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    const panel = document.getElementById('drawer-panel');
    const closeBtn = document.getElementById('drawer-close');

    function openDrawer() {
      if (!drawer || !backdrop || !panel) return;
      drawer.classList.remove('pointer-events-none');
      backdrop.classList.remove('pointer-events-none');
      backdrop.style.opacity = '1';
      panel.style.transform = 'translateX(0)';
    }

    function closeDrawer() {
      if (!drawer || !backdrop || !panel) return;
      backdrop.style.opacity = '0';
      panel.style.transform = 'translateX(-100%)';
      setTimeout(() => {
        drawer.classList.add('pointer-events-none');
        backdrop.classList.add('pointer-events-none');
      }, 300);
    }

    menuBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
  </script>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     PROSE — Aerospace-grade readability
     ═══════════════════════════════════════════════════════ */

  .doc {
    color: hsl(var(--foreground));
    line-height: 1.8;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
  }

  /* ── Headings ── */
  .doc h2 {
    font-family: 'Outfit Variable', system-ui, sans-serif;
    font-size: 1.625rem;
    font-weight: 700;
    color: hsl(var(--foreground));
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid hsl(var(--border));
    letter-spacing: -0.01em;
    scroll-margin-top: 5rem;
  }

  .doc h3 {
    font-family: 'Outfit Variable', system-ui, sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 5rem;
  }

  /* ── Body text ── */
  .doc p {
    margin-bottom: 1.25rem;
    color: hsl(0 0% 78%);
  }

  .doc > *:first-child {
    margin-top: 0;
  }

  /* ── Links ── */
  .doc a {
    color: hsl(var(--primary));
    text-decoration: none;
    font-weight: 500;
    text-underline-offset: 3px;
    transition: all 0.15s;
    border-bottom: 1px solid transparent;
  }

  .doc a:hover {
    color: hsl(var(--accent-teal-light));
    border-bottom-color: hsl(var(--primary) / 0.4);
  }

  /* ── Lists ── */
  .doc ul, .doc ol {
    margin-bottom: 1.25rem;
    padding-left: 1.25rem;
  }

  .doc li {
    margin-bottom: 0.375rem;
    color: hsl(0 0% 78%);
    padding-left: 0.25rem;
  }

  .doc li::marker {
    color: hsl(var(--primary) / 0.7);
  }

  .doc ol li::marker {
    color: hsl(var(--primary));
    font-weight: 700;
    font-size: 0.85em;
  }

  /* ── Inline code ── */
  .doc code {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.82em;
    background: hsl(var(--surface-2) / 0.7);
    border: 1px solid hsl(var(--border) / 0.6);
    border-radius: 5px;
    padding: 0.15em 0.45em;
    color: hsl(var(--accent-teal-light));
    font-weight: 500;
  }

  /* ── Code blocks ── */
  .doc pre {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.82rem;
    background: hsl(240 10% 2.5%);
    border: 1px solid hsl(var(--border) / 0.5);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 2rem;
    margin-top: 0.5rem;
    line-height: 1.7;
    position: relative;
    box-shadow: inset 0 1px 0 hsl(var(--primary) / 0.04), 0 4px 24px hsl(0 0% 0% / 0.3);
  }

  .doc pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
    color: hsl(0 0% 82%);
    font-weight: 400;
  }

  /* ── Blockquotes ── */
  .doc blockquote {
    border-left: 3px solid hsl(var(--primary) / 0.6);
    background: hsl(var(--surface-1) / 0.5);
    border-radius: 0 10px 10px 0;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    margin-top: 0.5rem;
    color: hsl(0 0% 70%);
    font-style: normal;
  }

  .doc blockquote p {
    color: inherit;
    margin-bottom: 0;
  }

  .doc blockquote strong {
    color: hsl(var(--foreground));
  }

  /* ── Tables ── */
  .doc table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-bottom: 2rem;
    font-size: 0.85rem;
