# Cloudflare Pages _headers
# Cache static assets aggressively for performance

# Fonts — long cache (1 year), immutable
/_astro/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/_astro/*.woff
  Cache-Control: public, max-age=31536000, immutable

# CSS and JS bundles — long cache, immutable (content-hashed by Vite)
/_astro/*.css
  Cache-Control: public, max-age=31536000, immutable

/_astro/*.js
  Cache-Control: public, max-age=31536000, immutable

# Images — moderate cache
/img/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/favicon.ico
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400

/og-default.png
  Cache-Control: public, max-age=86400

# HTML pages — short cache, allow revalidation
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers for all pages
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
