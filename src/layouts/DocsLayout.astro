---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'docs'>;
  entries: CollectionEntry<'docs'>[];
}

const { entry, entries } = Astro.props;

// ── Sidebar ──
interface SidebarGroup {
  label: string;
  slug: string;
  items: { title: string; slug: string; order: number }[];
}

const groups = new Map<string, SidebarGroup>();

for (const e of entries) {
  const parts = e.id.split('/');
  let group: SidebarGroup;

  if (parts.length >= 2) {
    const groupSlug = parts.slice(0, -1).join('/');
    const groupLabel = parts.slice(0, -1).map(p => p.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())).join(' / ');
    if (!groups.has(groupSlug)) {
      groups.set(groupSlug, { label: groupLabel, slug: groupSlug, items: [] });
    }
    group = groups.get(groupSlug)!;
  } else {
    if (!groups.has('_root')) {
      groups.set('_root', { label: 'Overview', slug: '', items: [] });
    }
    group = groups.get('_root')!;
  }

  group.items.push({ title: e.data.title, slug: e.id, order: e.data.order });
}

const sidebar = Array.from(groups.values())
  .sort((a, b) => {
    if (a.slug === '_root') return -1;
    if (b.slug === '_root') return 1;
    return a.slug.localeCompare(b.slug);
  })
  .map(g => ({ ...g, items: g.items.sort((a, b) => a.order - b.order) }));

const currentSlug = entry.id;

// ── Prev/next ──
const sorted = entries.map(e => ({ id: e.id, title: e.data.title, group: e.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join('/') })).sort((a, b) => a.id.localeCompare(b.id));
const idx = sorted.findIndex(e => e.id === currentSlug);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

const { Content, headings } = await render(entry);

// ── TOC: h2 + h3 only ──
const toc = headings
  .filter(h => h.depth === 2 || h.depth === 3)
  .map(h => ({ depth: h.depth, slug: h.slug, text: h.text }));
const hasToc = toc.length > 0;

// ── Group icons ──
const GROUP_ICONS: Record<string, string> = {
  'getting-started': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" /></svg>`,
  'admin-guide': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  'api-reference': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  'automation': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>`,
  'nodes': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>`,
  'user-guide': `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
};
---

<Layout title={entry.data.title} description={entry.data.description || `${entry.data.title} — Catalyst Documentation`} type="article" publishDate={new Date().toISOString().split('T')[0]} keywords={entry.data.keywords}>

  <!-- Reading progress -->
  <div class="fixed top-14 left-0 right-0 z-40 h-[2px]">
    <div class="h-full bg-primary/60 origin-left scale-x-0" id="progress-bar"></div>
  </div>

  <div class="flex min-h-[calc(100vh-3.5rem)]">

    <!-- ═══════════════════════════════════════════════
         LEFT SIDEBAR — Navigation
         ═══════════════════════════════════════════════ -->
    <aside class="hidden lg:flex flex-col w-60 shrink-0 border-r border-zinc-900/60 sticky top-14 h-[calc(100vh-3.5rem)] bg-surface-0/30" aria-label="Documentation navigation">
      <nav class="px-4 py-6 overflow-y-auto flex-1">
        <a href="/docs/" class="flex items-center gap-2.5 px-3 py-2 mb-4 text-zinc-500 hover:text-zinc-200 transition-colors rounded-lg hover:bg-surface-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="text-sm font-medium">Docs Home</span>
        </a>

        <div class="h-px bg-zinc-800/60 mx-3 mb-4"></div>

        {sidebar.map(group => (
          <div class="mb-5">
            <div class="flex items-center gap-2 px-3 mb-2 text-[10px] font-semibold uppercase tracking-[0.14em] text-zinc-600">
              {GROUP_ICONS[group.slug] && (
                <span class="text-zinc-700">
                  <Fragment set:html={GROUP_ICONS[group.slug]} />
                </span>
              )}
              {group.label}
            </div>
            <div class="space-y-px">
              {group.items.map(item => {
                const href = `/docs/${item.slug}/`;
                const active = item.slug === currentSlug;
                return (
                  <a
                    href={href}
                    class:list={[
                      "group relative flex items-center rounded-md px-3 py-[5px] text-[13px] leading-snug transition-all",
                      active
                        ? "text-foreground bg-surface-2 font-medium"
                        : "text-zinc-500 hover:text-zinc-300 hover:bg-surface-1",
                    ]}
                  >
                    {active && (
                      <span class="absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 rounded-r-full bg-primary" />
                    )}
                    <span class="truncate">{item.title}</span>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ═══════════════════════════════════════════════
         MOBILE DRAWER
         ═══════════════════════════════════════════════ -->
    <div id="mobile-drawer" class="lg:hidden fixed inset-0 z-50 hidden">
      <div id="drawer-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-72 bg-surface-0 border-r border-zinc-800/60 overflow-y-auto">
        <div class="flex items-center justify-between px-4 h-14 border-b border-zinc-800/60">
          <span class="text-sm font-semibold text-zinc-200">Docs</span>
          <button id="drawer-close" class="h-8 w-8 flex items-center justify-center rounded-lg text-zinc-500 hover:text-zinc-200" aria-label="Close">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <nav class="px-3 py-5 space-y-4">
          {sidebar.map(group => (
            <div>
              <div class="flex items-center gap-2 px-3 mb-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-600">
                {GROUP_ICONS[group.slug] && (
                  <span class="text-zinc-700"><Fragment set:html={GROUP_ICONS[group.slug]} /></span>
                )}
                {group.label}
              </div>
              <div class="space-y-px">
                {group.items.map(item => {
                  const href = `/docs/${item.slug}/`;
                  const active = item.slug === currentSlug;
                  return (
                    <a href={href} class:list={[
                      "relative flex items-center rounded-md px-3 py-[6px] text-[13px] transition-colors",
                      active ? "text-foreground bg-surface-2 font-medium" : "text-zinc-500 hover:text-zinc-300",
                    ]}>
                      {active && <span class="absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 rounded-r-full bg-primary" />}
                      {item.title}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </nav>
      </aside>
    </div>

    <!-- ═══════════════════════════════════════════════
         MAIN CONTENT
         ═══════════════════════════════════════════════ -->
    <div class="flex-1 min-w-0">
      <div class="max-w-3xl mx-auto px-6 sm:px-10 lg:px-16 py-12 lg:py-16">

        <!-- Mobile header -->
        <div class="lg:hidden flex items-center gap-3 mb-8">
          <button id="mobile-menu-btn" class="h-8 w-8 flex items-center justify-center rounded-lg border border-zinc-800/60 text-zinc-500 hover:text-zinc-200" aria-label="Menu">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
          </button>
          <nav class="text-xs text-zinc-600" aria-label="Breadcrumb">
            <a href="/docs/" class="hover:text-zinc-400">Docs</a>
            {entry.id.includes('/') && (
              <>
                <span class="mx-1.5">/</span>
                <span>{entry.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join(' / ')}</span>
              </>
            )}
            <span class="mx-1.5">/</span>
            <span class="text-zinc-400">{entry.data.title}</span>
          </nav>
        </div>

        <!-- Title -->
        <header class="mb-14">
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-foreground leading-tight">{entry.data.title}</h1>
          {entry.data.description && (
            <p class="mt-4 text-lg text-zinc-500 leading-relaxed">{entry.data.description}</p>
          )}
        </header>

        <!-- Markdown body -->
        <div class="doc">
          <Content />
        </div>

        <!-- Prev / Next -->
        {(prev || next) && (
          <nav class="mt-20 pt-8 border-t border-zinc-800/60 grid grid-cols-1 sm:grid-cols-2 gap-4">
            {prev && (
              <a href={`/docs/${prev.id}/`} class="group rounded-xl border border-zinc-800/60 bg-surface-1 p-5 hover:border-zinc-700 hover:bg-surface-2 transition-all">
                <span class="text-[10px] uppercase tracking-widest text-zinc-600 mb-1 block">Previous</span>
                <span class="text-sm font-medium text-zinc-400 group-hover:text-foreground transition-colors">{prev.title}</span>
              </a>
            )}
            {next && (
              <a href={`/docs/${next.id}/`} class:list={[
                "group rounded-xl border border-zinc-800/60 bg-surface-1 p-5 hover:border-zinc-700 hover:bg-surface-2 transition-all text-right",
                !prev && "sm:col-start-2",
              ]}>
                <span class="text-[10px] uppercase tracking-widest text-zinc-600 mb-1 block">Next</span>
                <span class="text-sm font-medium text-zinc-400 group-hover:text-foreground transition-colors">{next.title}</span>
              </a>
            )}
          </nav>
        )}

        <div class="h-32"></div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         RIGHT SIDEBAR — Table of Contents
         ═══════════════════════════════════════════════ -->
    {hasToc && (
      <aside class="hidden xl:flex flex-col w-56 shrink-0 border-l border-zinc-900/60 sticky top-14 h-[calc(100vh-3.5rem)] bg-surface-0/30" aria-label="Table of contents">
        <nav class="px-4 py-8 overflow-y-auto no-scrollbar">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-3.5 h-3.5 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-zinc-500">On this page</span>
          </div>
          <div class="relative">
            {/* Active indicator line */}
            <div id="toc-indicator" class="absolute left-0 w-[2px] rounded-full bg-primary transition-all duration-200" style="top: 0; height: 20px;"></div>
            <div class="space-y-0.5">
              {toc.map(h => (
                <a
                  href={`#${h.slug}`}
                  data-toc-link
                  data-slug={h.slug}
                  data-depth={h.depth}
                  class:list={[
                    "block py-[5px] pr-2 text-[12px] leading-snug transition-colors rounded border-l-2 border-transparent",
                    h.depth === 3 ? "pl-4 text-zinc-600 hover:text-zinc-400" : "pl-3 text-zinc-500 hover:text-zinc-300",
                  ]}
                >
                  {h.text}
                </a>
              ))}
            </div>
          </div>
        </nav>
      </aside>
    )}
  </div>

  <script>
    // Progress bar
    const bar = document.getElementById('progress-bar');
    addEventListener('scroll', () => {
      if (!bar) return;
      const p = scrollY / (document.documentElement.scrollHeight - innerHeight);
      bar.style.transform = `scaleX(${Math.min(p, 1)})`;
    }, { passive: true });

    // Mobile drawer
    const openDrawer = () => document.getElementById('mobile-drawer')?.classList.remove('hidden');
    const closeDrawer = () => document.getElementById('mobile-drawer')?.classList.add('hidden');
    document.getElementById('mobile-menu-btn')?.addEventListener('click', openDrawer);
    document.getElementById('drawer-close')?.addEventListener('click', closeDrawer);
    document.getElementById('drawer-backdrop')?.addEventListener('click', closeDrawer);

    // TOC scroll-spy with IntersectionObserver
    const tocLinks = document.querySelectorAll('[data-toc-link]');
    const tocIndicator = document.getElementById('toc-indicator');

    if (tocLinks.length) {
      const docEl = document.querySelector('.doc');
      const headings = docEl ? [...docEl.querySelectorAll('h2[id], h3[id]')] : [];

      // Smooth scroll for TOC clicks
      tocLinks.forEach(a => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) {
            const y = target.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top: y, behavior: 'smooth' });
            history.replaceState(null, null, a.getAttribute('href'));
          }
        });
      });

      // IntersectionObserver for accurate section detection
      const observerOptions = {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      };

      let activeId = '';

      const observer = new IntersectionObserver((entries) => {
        // Find the topmost visible heading
        let topmost = null;
        let topmostY = Infinity;

        for (const entry of entries) {
          if (entry.isIntersecting) {
            const rect = entry.target.getBoundingClientRect();
            if (rect.top < topmostY) {
              topmostY = rect.top;
              topmost = entry.target;
            }
          }
        }

        // If nothing is intersecting from the top, check which heading we just passed
        if (!topmost) {
          for (const h of headings) {
            const rect = h.getBoundingClientRect();
            if (rect.top <= 80) {
              topmost = h;
            }
          }
        }

        if (topmost) {
          activeId = topmost.id;
          updateToc(activeId);
        }
      }, observerOptions);

      headings.forEach(h => observer.observe(h));

      function updateToc(activeId) {
        let activeLink = null;

        tocLinks.forEach(a => {
          const match = a.dataset.slug === activeId;
          a.classList.toggle('text-foreground', match);
          a.classList.toggle('font-medium', match);
          a.classList.toggle('border-primary', match);
          a.classList.toggle('text-zinc-500', !match);
          a.classList.toggle('border-transparent', !match);

          if (a.dataset.depth === '3') {
            a.classList.toggle('text-zinc-600', !match);
          }

          if (match) activeLink = a;
        });

        // Move the indicator to the active link
        if (activeLink && tocIndicator) {
          const container = activeLink.closest('.relative');
          if (container) {
            const containerRect = container.getBoundingClientRect();
            const linkRect = activeLink.getBoundingClientRect();
            const relativeTop = linkRect.top - containerRect.top + container.scrollTop;
            tocIndicator.style.transform = `translateY(${relativeTop}px)`;
            tocIndicator.style.height = `${linkRect.height}px`;
          }
        }

        // Scroll active link into view within the TOC sidebar
        if (activeLink) {
          const sidebarNav = activeLink.closest('nav');
          if (sidebarNav) {
            const linkRect = activeLink.getBoundingClientRect();
            const navRect = sidebarNav.getBoundingClientRect();
            const linkTop = linkRect.top - navRect.top + sidebarNav.scrollTop;
            const linkBottom = linkTop + linkRect.height;

            if (linkTop < sidebarNav.scrollTop) {
              sidebarNav.scrollTo({ top: linkTop - 8, behavior: 'smooth' });
            } else if (linkBottom > sidebarNav.scrollTop + navRect.height) {
              sidebarNav.scrollTo({ top: linkBottom - navRect.height + 8, behavior: 'smooth' });
            }
          }
        }
      }

      // Initial state
      updateToc(headings[0]?.id || '');
    }
  </script>
</Layout>
