---
import Layout from "../layouts/Layout.astro";

const B = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "") + "/";
const GITHUB_URL = "https://github.com/catalystctl/catalyst";

const autoSteps = [
  {
    number: "01",
    title: "Deploy Catalyst",
    description: "Install Catalyst on your target server using the one-line installer. The script sets up Docker Compose, generates secrets, and configures the panel automatically.",
    details: [
      "Run: curl -fsSL https://raw.githubusercontent.com/catalystctl/catalyst/main/install.sh | bash",
      "Edit the generated .env file and set PUBLIC_URL to your domain",
      "Run docker compose up -d to start the panel, API, and database",
      "Provision at least one Catalyst node and verify it is online",
    ],
  },
  {
    number: "02",
    title: "Connect your Pterodactyl panel",
    description: "Generate API keys from your existing Pterodactyl panel and test the connection from Catalyst's built-in migration tool.",
    details: [
      "In Pterodactyl, create an Application API key (ptla_*) with full read access",
      "Create a Client API key (ptlc_*) for file and backup migration",
      "In Catalyst, go to Admin → Migration and enter your Pterodactyl URL and keys",
      "Click Test Connection to verify Catalyst can reach your Pterodactyl API",
    ],
  },
  {
    number: "03",
    title: "Map nodes & start migration",
    description: "Choose what to migrate and map your Pterodactyl nodes to Catalyst nodes. Then start the migration and watch it run.",
    details: [
      "Select scope: full (everything), node (specific nodes), or server (individual servers)",
      "Map each Pterodactyl node to a corresponding Catalyst node",
      "Click Start Migration — Catalyst automatically imports users, eggs, allocations, and servers",
      "Monitor progress in real-time: steps, status, and per-server results",
    ],
  },
  {
    number: "04",
    title: "Verify & cut over",
    description: "Once migration completes, validate a few servers, update DNS, and decommission Pterodactyl.",
    details: [
      "Start a migrated server and verify it boots correctly via the Catalyst console",
      "Check that file ownership, permissions, and configs transferred properly",
      "Update DNS A records to point to the Catalyst panel",
      "Stop Pterodactyl services and monitor Catalyst logs for 24–48 hours",
    ],
  },
];

const migratedItems = [
  {
    title: "Nodes & Allocations",
    description: "Pterodactyl nodes are mapped to Catalyst nodes. IP allocations and port ranges are recreated automatically.",
  },
  {
    title: "Users & Roles",
    description: "User accounts, emails, and passwords are imported. Basic Pterodactyl admin/user roles map to Catalyst's RBAC system.",
  },
  {
    title: "Eggs & Templates",
    description: "Egg configurations are converted to Catalyst templates. Variables, images, install scripts, and startup commands transfer as-is.",
  },
  {
    title: "Servers & Files",
    description: "Server specs, environment variables, and port bindings are recreated. File data is streamed directly from Pterodactyl to Catalyst nodes.",
  },
];

const faqs = [
  {
    q: "Will my Pterodactyl eggs work in Catalyst?",
    a: "Yes. Catalyst's migration tool converts Pterodactyl eggs to Catalyst templates automatically. Startup commands, environment variables, and install scripts transfer with minimal or no changes. Because Catalyst uses containerd instead of Docker, some Docker Compose-specific commands may need minor review.",
  },
  {
    q: "Can I run Catalyst and Pterodactyl side by side?",
    a: "Yes, during migration. Install Catalyst on a separate server or use different ports. Both can access the same nodes if configured with non-overlapping port allocations. This lets you validate Catalyst before cutting over.",
  },
  {
    q: "What happens to my existing server files?",
    a: "Server files are streamed directly from Pterodactyl's Docker volumes to Catalyst's containerd storage during migration. The file structure is preserved, and Catalyst's built-in file manager lets you verify everything transferred correctly.",
  },
  {
    q: "How long does migration take?",
    a: "Configuration migration (users, eggs, nodes, allocations, server metadata) completes in minutes. File transfers depend on total data size and network speed. A small-to-medium host with under 50 servers typically finishes in under an hour.",
  },
  {
    q: "Is there an automatic migration tool?",
    a: "Yes. Catalyst has a built-in Pterodactyl migration tool available in the admin panel at Admin → Migration. It imports nodes, allocations, users, eggs, servers, and files automatically. You can also monitor, pause, resume, and retry migration jobs.",
  },
  {
    q: "Can I migrate only some servers?",
    a: "Yes. The migration tool supports three scopes: full (everything), node (all servers on specific nodes), and server (individual servers). You can run multiple migrations or retry failed steps without starting over.",
  },
];
---

<Layout
  title="Migrate from Pterodactyl"
  description="Migrate from Pterodactyl to Catalyst automatically. Import nodes, users, eggs, servers, and files with Catalyst's built-in migration tool."
  keywords={["migrate from pterodactyl", "pterodactyl to catalyst", "pterodactyl migration", "switch from pterodactyl", "pterodactyl replacement guide", "move servers from pterodactyl", "auto migration pterodactyl"]}
  canonicalUrl="https://catalystctl.com/migrate-from-pterodactyl/"
>
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach((el) => observer.observe(el));
  </script>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-8 sm:pt-16 sm:pb-10">
    <nav class="text-xs text-zinc-600 mb-6" aria-label="Breadcrumb">
      <a href={B} class="hover:text-zinc-400 transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-400">Migrate from Pterodactyl</span>
    </nav>

    <div data-reveal>
      <div class="flex items-center gap-2 mb-4">
        <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
        </svg>
        <span class="text-xs font-semibold tracking-wider uppercase text-primary">Migration Guide</span>
      </div>
      <h1 class="font-display font-bold text-foreground tracking-tight leading-[1.05]" style="font-size: clamp(2rem, 6vw, 4rem);">
        Migrate from <span class="text-zinc-500">Pterodactyl</span> to Catalyst.
      </h1>
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-zinc-400 leading-relaxed">
        Catalyst includes a built-in auto-migration tool that imports your Pterodactyl nodes, users, eggs, servers, and files — directly from the admin panel. No manual scripting required.
      </p>
    </div>
  </section>

  <!-- Overview -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" data-reveal-stagger>
      <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-5">
        <div class="font-display text-3xl font-bold text-foreground">&lt;1 hour</div>
        <p class="mt-1 text-sm text-zinc-500">Typical migration time for under 50 servers</p>
      </div>
      <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-5">
        <div class="font-display text-3xl font-bold text-foreground">60s</div>
        <p class="mt-1 text-sm text-zinc-500">Catalyst install time with the one-line script</p>
      </div>
      <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-5">
        <div class="font-display text-3xl font-bold text-foreground">Auto</div>
        <p class="mt-1 text-sm text-zinc-500">Built-in migration tool handles the heavy lifting</p>
      </div>
    </div>
  </section>

  <!-- Auto Migration Highlight -->
  <section class="max-w-6xl mx-auto px-4 py-8">
    <div class="rounded-2xl border border-primary/20 bg-primary/5 p-8 sm:p-10" data-reveal>
      <div class="flex items-start gap-4">
        <div class="shrink-0 mt-1">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/15 text-primary">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </div>
        </div>
        <div>
          <h2 class="font-display text-xl sm:text-2xl font-semibold text-foreground tracking-tight">Built-in auto migration</h2>
          <p class="mt-2 text-sm sm:text-base text-zinc-400 leading-relaxed max-w-2xl">
            Catalyst's admin panel includes a native Pterodactyl migration tool. Connect your Pterodactyl API, choose what to import, and Catalyst handles the rest — nodes, allocations, users, eggs, servers, and file data. Monitor progress in real-time, pause, resume, or retry individual steps.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">Nodes & Allocations</span>
            <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">Users & Roles</span>
            <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">Eggs & Templates</span>
            <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">Servers & Files</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="max-w-6xl mx-auto px-4 py-16" aria-label="Migration steps">
    <div class="mb-10" data-reveal>
      <h2 class="font-display text-sm font-semibold tracking-[0.12em] uppercase text-zinc-500">The process</h2>
      <p class="mt-2 text-2xl sm:text-3xl font-display font-semibold text-foreground tracking-tight">Four steps to a clean migration.</p>
    </div>

    <div class="space-y-8" data-reveal-stagger>
      {autoSteps.map((step) => (
        <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-6 sm:p-8">
          <div class="flex items-start gap-4 sm:gap-6">
            <div class="shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary font-display text-lg font-bold">
                {step.number}
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-display text-lg font-semibold text-foreground">{step.title}</h3>
              <p class="mt-1 text-sm text-zinc-400 leading-relaxed">{step.description}</p>
              <ul class="mt-4 space-y-2">
                {step.details.map((d) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-500">
                    <svg class="w-3.5 h-3.5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    <span class="font-mono text-[12px] text-zinc-400">{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- What Gets Migrated -->
  <section class="max-w-6xl mx-auto px-4 py-16" aria-label="What gets migrated">
    <div class="mb-10" data-reveal>
      <h2 class="font-display text-sm font-semibold tracking-[0.12em] uppercase text-zinc-500">What gets migrated</h2>
      <p class="mt-2 text-2xl sm:text-3xl font-display font-semibold text-foreground tracking-tight">Everything you need.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-reveal-stagger>
      {migratedItems.map((item) => (
        <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-6">
          <h3 class="font-display text-base font-semibold text-foreground">{item.title}</h3>
          <p class="mt-2 text-sm text-zinc-500 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Compatibility -->
  <section class="max-w-6xl mx-auto px-4 py-16" aria-label="Compatibility notes">
    <div class="max-w-3xl" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-foreground tracking-tight mb-8">Compatibility at a glance</h2>

      <div class="space-y-6 text-zinc-400 leading-relaxed">
        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">Eggs and startup commands</h3>
          <p>Catalyst's template system is conceptually identical to Pterodactyl's eggs. The migration tool converts eggs automatically — startup commands, environment variables, and install scripts transfer with minimal changes. The main difference is that Catalyst uses containerd directly, so any Docker Compose-specific configuration should be reviewed.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">Server files and volumes</h3>
          <p>Pterodactyl stores server files in Docker volumes under /var/lib/pterodactyl/volumes. During migration, Catalyst streams these files directly to containerd snapshotter storage. The internal file layout is preserved, and Catalyst's built-in file manager lets you verify everything migrated correctly.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">Users and permissions</h3>
          <p>Pterodactyl's basic admin/user roles map cleanly to Catalyst's RBAC system, but Catalyst gives you far more control. Instead of binary permissions, you can create custom roles with exactly the access each user needs. Plan to spend a few minutes tuning permissions after import.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">API integrations</h3>
          <p>Catalyst's REST API is different from Pterodactyl's, but it's more comprehensive. Any bots, billing integrations, or automation scripts will need to be updated to use Catalyst's 60+ endpoints. The good news: Catalyst's API is better documented and more consistent.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-6xl mx-auto px-4 py-16" aria-label="Migration FAQ">
    <div class="mb-10" data-reveal>
      <h2 class="font-display text-sm font-semibold tracking-[0.12em] uppercase text-zinc-500">FAQ</h2>
      <p class="mt-2 text-2xl sm:text-3xl font-display font-semibold text-foreground tracking-tight">Common migration questions.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" data-reveal-stagger>
      {faqs.map((faq) => (
        <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-6">
          <h3 class="font-semibold text-foreground text-[15px]">{faq.q}</h3>
          <p class="mt-2 text-sm text-zinc-500 leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>

    <!-- FAQPage JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    })} />
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="relative rounded-2xl border border-zinc-800/60 bg-surface-1 p-8 sm:p-12 text-center overflow-hidden" data-reveal>
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1510]/50 via-transparent to-transparent pointer-events-none"></div>
      <div class="relative">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-foreground tracking-tight">Start your migration today</h2>
        <p class="mt-3 text-base text-zinc-500 max-w-md mx-auto">Deploy Catalyst in 60 seconds and import your Pterodactyl data automatically.</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-all duration-200 hover:bg-primary-600 min-h-11">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Install Catalyst
          </a>
          <a href={B + "vs-pterodactyl/"} class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 px-5 py-3 text-sm font-medium text-zinc-400 transition-all duration-200 hover:bg-surface-2 hover:text-zinc-200 min-h-11">
            Full Comparison
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="h-8"></div>
</Layout>
