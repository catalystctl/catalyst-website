---
import Layout from "../layouts/Layout.astro";

const B = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "") + "/";
const GITHUB_URL = "https://github.com/catalystctl/catalyst";

const comparisons = [
  {
    category: "Architecture",
    rows: [
      { feature: "Backend language", catalyst: "Rust (Axum)", pterodactyl: "PHP (Laravel)", winner: "catalyst" },
      { feature: "Frontend", catalyst: "TypeScript (React + Vite)", pterodactyl: "React + Laravel Mix", winner: "catalyst" },
      { feature: "Container runtime", catalyst: "containerd (native)", pterodactyl: "Docker (layered)", winner: "catalyst" },
      { feature: "WebSocket implementation", catalyst: "Native Rust (Axum)", pterodactyl: "Node.js (ws)", winner: "catalyst" },
      { feature: "Database", catalyst: "PostgreSQL", pterodactyl: "MySQL / MariaDB", winner: "tie" },
    ],
  },
  {
    category: "Performance",
    rows: [
      { feature: "Console latency", catalyst: "< 10ms", pterodactyl: "~100ms", winner: "catalyst" },
      { feature: "Memory footprint (panel)", catalyst: "~50MB", pterodactyl: "~200MB+", winner: "catalyst" },
      { feature: "Startup time", catalyst: "< 1s", pterodactyl: "~5s", winner: "catalyst" },
      { feature: "Container overhead", catalyst: "Minimal (containerd)", pterodactyl: "Higher (Docker daemon)", winner: "catalyst" },
      { feature: "Concurrent connections", catalyst: "10,000+", pterodactyl: "~1,000", winner: "catalyst" },
    ],
  },
  {
    category: "Features",
    rows: [
      { feature: "REST API endpoints", catalyst: "60+", pterodactyl: "~40", winner: "catalyst" },
      { feature: "Plugin system", catalyst: "Native (hooks + routes)", pterodactyl: "None", winner: "catalyst" },
      { feature: "RBAC permissions", catalyst: "20+ granular", pterodactyl: "Basic (admin/user)", winner: "catalyst" },
      { feature: "API key management", catalyst: "Scoped + expiring", pterodactyl: "Basic", winner: "catalyst" },
      { feature: "Audit logging", catalyst: "Built-in", pterodactyl: "Third-party only", winner: "catalyst" },
      { feature: "Auto crash recovery", catalyst: "Yes", pterodactyl: "Partial", winner: "catalyst" },
      { feature: "SFTP support", catalyst: "Built-in", pterodactyl: "Built-in", winner: "tie" },
      { feature: "Scheduling / cron", catalyst: "Native tasks", pterodactyl: "Basic", winner: "catalyst" },
    ],
  },
  {
    category: "Operations",
    rows: [
      { feature: "Installation", catalyst: "Single script (60s)", pterodactyl: "Manual + Wings daemon", winner: "catalyst" },
      { feature: "Node agent", catalyst: "Lightweight Rust binary", pterodactyl: "Wings (Node.js)", winner: "catalyst" },
      { feature: "TLS / HTTPS", catalyst: "Auto (Let's Encrypt ready)", pterodactyl: "Manual setup", winner: "catalyst" },
      { feature: "Backup system", catalyst: "S3-compatible", pterodactyl: "S3-compatible", winner: "tie" },
      { feature: "Multi-node clustering", catalyst: "Native", pterodactyl: "Via Wings", winner: "tie" },
    ],
  },
];

const verdicts = [
  {
    title: "Choose Catalyst if...",
    points: [
      "You want a modern, Rust-based stack with superior performance",
      "You need a plugin system to extend functionality without forking",
      "You want sub-10ms WebSocket console latency",
      "You prefer a single-script install over manual configuration",
      "You need granular RBAC with 20+ permissions",
      "You want 60+ REST API endpoints for full automation",
    ],
  },
  {
    title: "Stick with Pterodactyl if...",
    points: [
      "You have a large existing installation and no migration bandwidth",
      "Your team is deeply familiar with PHP/Laravel ecosystems",
      "You rely on third-party Pterodactyl-specific plugins/themes",
      "You need mature multi-language community support today",
    ],
  },
];
---

<Layout
  title="Catalyst vs Pterodactyl"
  description="Detailed side-by-side comparison of Catalyst and Pterodactyl. Architecture, performance, features, and operations — see why Catalyst is the modern Pterodactyl replacement."
  keywords={["catalyst vs pterodactyl", "pterodactyl alternative", "pterodactyl replacement", "game server panel comparison", "pterodactyl vs", "rust game server panel", "containerd vs docker"]}
  canonicalUrl="https://catalystctl.com/vs-pterodactyl/"
>
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach((el) => observer.observe(el));
  </script>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-8 sm:pt-16 sm:pb-10">
    <nav class="text-xs text-zinc-600 mb-6" aria-label="Breadcrumb">
      <a href={B} class="hover:text-zinc-400 transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-400">Catalyst vs Pterodactyl</span>
    </nav>

    <div data-reveal>
      <h1 class="font-display font-bold text-foreground tracking-tight leading-[1.05]" style="font-size: clamp(2rem, 6vw, 4rem);">
        Catalyst vs <span class="text-zinc-500">Pterodactyl</span>
      </h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg text-zinc-400 leading-relaxed">
        A detailed, no-BS comparison of the two leading game server management platforms. See why Catalyst is the best Pterodactyl replacement for modern hosting operations.
      </p>
    </div>
  </section>

  <!-- Summary cards -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" data-reveal-stagger>
      <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-5">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-primary mb-1">Catalyst</div>
        <div class="font-display text-3xl font-bold text-foreground">Rust + containerd</div>
        <p class="mt-2 text-sm text-zinc-500">Modern stack. Sub-10ms latency. Single-script install.</p>
      </div>
      <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-5">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-500 mb-1">Pterodactyl</div>
        <div class="font-display text-3xl font-bold text-zinc-400">PHP + Docker</div>
        <p class="mt-2 text-sm text-zinc-500">Mature ecosystem. ~100ms latency. Manual install.</p>
      </div>
      <div class="rounded-xl border border-primary/20 bg-primary/[0.04] p-5">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-primary mb-1">Result</div>
        <div class="font-display text-3xl font-bold text-foreground">Catalyst wins</div>
        <p class="mt-2 text-sm text-zinc-400">Faster, more secure, more extensible. Early testing phase.</p>
      </div>
    </div>
  </section>

  <!-- Comparison tables -->
  <section class="max-w-6xl mx-auto px-4 py-12 space-y-16" aria-label="Detailed comparison">
    {comparisons.map((section) => (
      <div data-reveal>
        <h2 class="font-display text-sm font-semibold tracking-[0.12em] uppercase text-zinc-500 mb-6">{section.category}</h2>
        <div class="rounded-xl border border-zinc-800/60 overflow-hidden">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-zinc-800/60 bg-surface-1">
                <th class="py-3 px-5 text-[11px] font-semibold uppercase tracking-wider text-zinc-500 w-[30%]">Feature</th>
                <th class="py-3 px-5 text-[11px] font-semibold uppercase tracking-wider text-primary w-[35%]">Catalyst</th>
                <th class="py-3 px-5 text-[11px] font-semibold uppercase tracking-wider text-zinc-500 w-[35%]">Pterodactyl</th>
              </tr>
            </thead>
            <tbody>
              {section.rows.map((row) => (
                <tr class="border-b border-zinc-800/40 last:border-0 hover:bg-surface-1/50 transition-colors">
                  <td class="py-3.5 px-5 text-sm text-zinc-400">{row.feature}</td>
                  <td class="py-3.5 px-5 text-sm font-medium text-foreground">
                    <span class="inline-flex items-center gap-1.5">
                      {row.winner === "catalyst" && <span class="w-1.5 h-1.5 rounded-full bg-success shrink-0" aria-hidden="true" />}
                      {row.catalyst}
                    </span>
                  </td>
                  <td class="py-3.5 px-5 text-sm text-zinc-600">
                    <span class="inline-flex items-center gap-1.5">
                      {row.winner === "pterodactyl" && <span class="w-1.5 h-1.5 rounded-full bg-success shrink-0" aria-hidden="true" />}
                      {row.pterodactyl}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </section>

  <!-- Verdict -->
  <section class="max-w-6xl mx-auto px-4 py-12" aria-label="Verdict">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" data-reveal-stagger>
      {verdicts.map((v) => (
        <div class="rounded-xl border border-zinc-800/60 bg-surface-1 p-6">
          <h3 class="font-display text-lg font-semibold text-foreground mb-4">{v.title}</h3>
          <ul class="space-y-3">
            {v.points.map((p) => (
              <li class="flex items-start gap-3 text-sm text-zinc-400">
                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {p}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Deep dive content for SEO -->
  <section class="max-w-6xl mx-auto px-4 py-16" aria-label="Detailed analysis">
    <div class="max-w-3xl" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-foreground tracking-tight mb-8">Why Catalyst is the best Pterodactyl replacement</h2>

      <div class="space-y-8 text-zinc-400 leading-relaxed">
        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">Rust instead of PHP</h3>
          <p>Pterodactyl's PHP/Laravel backend has served the community well, but it comes with inherent limitations: higher memory usage, slower cold starts, and a dependency on the PHP runtime. Catalyst's Rust backend compiles to a single native binary with zero runtime dependencies. The result is a panel that starts in under a second, uses a fraction of the RAM, and handles 10x more concurrent WebSocket connections.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">containerd instead of Docker</h3>
          <p>Both platforms use containers, but the runtime matters. Pterodactyl relies on the Docker daemon, which adds a management layer and higher resource overhead. Catalyst uses containerd directly — the same runtime that powers Kubernetes. This means faster container startups, lower memory footprint per server, and no Docker daemon to maintain.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">A plugin system Pterodactyl lacks</h3>
          <p>One of the biggest complaints from Pterodactyl power users is the lack of extensibility. Want to add custom API endpoints? You fork the project. Catalyst solves this with a native plugin system: write TypeScript, register hooks, add routes, and schedule background tasks — all without touching core code.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">Granular security</h3>
          <p>Pterodactyl's permission model is binary: admin or user. Catalyst ships with 20+ granular permissions covering server control, file access, node management, API key creation, and audit log viewing. This lets you create roles like "support staff" who can restart servers but can't delete nodes.</p>
        </div>

        <div>
          <h3 class="text-foreground font-semibold text-lg mb-2">60+ REST API endpoints</h3>
          <p>Automation is where Catalyst shines. With 60+ documented REST endpoints — compared to Pterodactyl's ~40 — you can script every aspect of your hosting operation: provision servers, manage users, configure nodes, and monitor health, all via API.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="relative rounded-2xl border border-zinc-800/60 bg-surface-1 p-8 sm:p-12 text-center overflow-hidden" data-reveal>
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1510]/50 via-transparent to-transparent pointer-events-none"></div>
      <div class="relative">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-foreground tracking-tight">Ready to make the switch?</h2>
        <p class="mt-3 text-base text-zinc-500 max-w-md mx-auto">Deploy Catalyst in 60 seconds and see the difference for yourself.</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-all duration-200 hover:bg-primary-600 min-h-11">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Get Started on GitHub
          </a>
          <a href={B + "migrate-from-pterodactyl/"} class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 px-5 py-3 text-sm font-medium text-zinc-400 transition-all duration-200 hover:bg-surface-2 hover:text-zinc-200 min-h-11">
            Migration Guide
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="h-8"></div>
</Layout>
