---
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/outfit';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Fast, secure, modern game server management platform." } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/screenshots", label: "Screenshots" },
];

const GITHUB_URL = "https://github.com/catalystctl/catalyst";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title === "Home" ? "Catalyst" : `${title} — Catalyst`}</title>
  </head>

  <body class="min-h-screen bg-background text-foreground">
    <!-- Top nav — matches panel Header component exactly -->
    <header class="sticky top-0 z-50 flex items-center justify-between border-b border-zinc-800 bg-surface-1/80 backdrop-blur-md shadow-surface-dark px-4 h-14">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo.png" alt="Catalyst logo" class="h-6 w-6 rounded" />
          <span class="font-display text-lg font-semibold text-zinc-100">Catalyst</span>
        </a>
      </div>

      <div class="flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-all duration-200",
              currentPath === link.href
                ? "bg-primary text-primary-foreground shadow-sm"
                : "text-zinc-400 hover:bg-surface-2 hover:text-zinc-100",
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="w-px h-5 bg-zinc-800 mx-2"></div>
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-3 py-2 text-xs font-medium text-primary-foreground shadow-sm transition-all duration-200 hover:bg-primary-600"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer — matches panel BrandFooter pattern -->
    <footer class="border-t border-zinc-800 mt-24">
      <div class="max-w-6xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-1 text-xs text-muted-foreground/60">
          Made with
          <svg class="inline h-3 w-3 fill-rose-400 text-rose-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          by
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="font-medium text-foreground/70 hover:text-foreground transition-colors">Catalyst</a>
          &middot; GPLv3
        </div>
        <div class="flex items-center gap-4">
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-xs text-muted-foreground hover:text-foreground transition-colors">GitHub</a>
          <a href="https://github.com/catalystctl/catalyst/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="text-xs text-muted-foreground hover:text-foreground transition-colors">Contributing</a>
          <a href="https://github.com/catalystctl/catalyst/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-xs text-muted-foreground hover:text-foreground transition-colors">License</a>
        </div>
      </div>
    </footer>
  </body>
</html>
