{
  "name": "catalyst-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prebuild": "scripts/sync-docs.sh && scripts/copy-screenshots.sh && node scripts/generate-screenshot-data.js",
    "predev": "scripts/sync-docs.sh && scripts/copy-screenshots.sh",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "screenshots": "scripts/copy-screenshots.sh",
    "docs": "scripts/sync-docs.sh",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
