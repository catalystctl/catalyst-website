---
import Layout from "../layouts/Layout.astro";

const B = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "") + "/";
const GITHUB_URL = "https://github.com/catalystctl/catalyst";
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">

  <section class="max-w-6xl mx-auto px-4 pt-20 pb-24 text-center">
    <div class="mb-6">
      <span class="font-display text-8xl font-bold text-zinc-800">404</span>
    </div>
    <h1 class="font-display text-2xl sm:text-3xl font-semibold text-foreground tracking-tight">
      Page not found
    </h1>
    <p class="mt-3 text-base text-zinc-500 max-w-md mx-auto">
      The page you're looking for doesn't exist or has been moved. Try one of these links instead.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href={B} class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-all duration-200 hover:bg-primary-600 min-h-11">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
        Go Home
      </a>
      <a href={B + "docs/"} class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 bg-transparent px-5 py-3 text-sm font-medium text-zinc-300 transition-all duration-200 hover:bg-surface-2 hover:text-zinc-100 min-h-11">
        Documentation
      </a>
      <a href={B + "pterodactyl-alternative/"} class="inline-flex items-center gap-2 rounded-lg border border-zinc-800 bg-transparent px-5 py-3 text-sm font-medium text-zinc-300 transition-all duration-200 hover:bg-surface-2 hover:text-zinc-100 min-h-11">
        Pterodactyl Alternative
      </a>
    </div>
    <div class="mt-12">
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">
        Think this is a bug? Open an issue on GitHub
      </a>
    </div>
  </section>

</Layout>
