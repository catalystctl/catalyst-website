---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'docs'>;
  entries: CollectionEntry<'docs'>[];
}

const { entry, entries } = Astro.props;

// ── Sidebar ──
interface SidebarGroup {
  label: string;
  slug: string;
  items: { title: string; slug: string; order: number }[];
}

const groups = new Map<string, SidebarGroup>();

for (const e of entries) {
  const parts = e.id.split('/');
  let group: SidebarGroup;

  if (parts.length >= 2) {
    const groupSlug = parts.slice(0, -1).join('/');
    const groupLabel = parts.slice(0, -1).map(p => p.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())).join(' / ');
    if (!groups.has(groupSlug)) {
      groups.set(groupSlug, { label: groupLabel, slug: groupSlug, items: [] });
    }
    group = groups.get(groupSlug)!;
  } else {
    if (!groups.has('_root')) {
      groups.set('_root', { label: 'Overview', slug: '', items: [] });
    }
    group = groups.get('_root')!;
  }

  group.items.push({ title: e.data.title, slug: e.id, order: e.data.order });
}

const sidebar = Array.from(groups.values())
  .sort((a, b) => {
    if (a.slug === '_root') return -1;
    if (b.slug === '_root') return 1;
    return a.slug.localeCompare(b.slug);
  })
  .map(g => ({ ...g, items: g.items.sort((a, b) => a.order - b.order) }));

const currentSlug = entry.id;

// ── Prev/next ──
const sorted = entries.map(e => ({ id: e.id, title: e.data.title, group: e.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join('/') })).sort((a, b) => a.id.localeCompare(b.id));
const idx = sorted.findIndex(e => e.id === currentSlug);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description || `${entry.data.title} — Catalyst Documentation`} type="article">

  <!-- Reading progress -->
  <div class="fixed top-14 left-0 right-0 z-40 h-[2px]">
    <div class="h-full bg-primary/60 origin-left scale-x-0" id="progress-bar"></div>
  </div>

  <div class="flex min-h-[calc(100vh-3.5rem)]">

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="hidden lg:block w-60 shrink-0 border-r border-zinc-800/50 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto bg-zinc-950/30">
      <nav class="px-3 py-6" aria-label="Documentation">
        <a href="/docs/" class="flex items-center gap-2.5 px-3 mb-5 text-zinc-400 hover:text-zinc-200 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="text-sm font-medium">Docs</span>
        </a>

        {sidebar.map(group => (
          <div class="mb-5">
            <div class="px-3 mb-1.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-600">{group.label}</div>
            <div class="space-y-px">
              {group.items.map(item => {
                const href = `/docs/${item.slug}/`;
                const active = item.slug === currentSlug;
                return (
                  <a
                    href={href}
                    class:list={[
                      "relative block rounded-md px-3 py-[6px] text-[13px] leading-snug transition-colors",
                      active ? "text-zinc-100 bg-zinc-800/80 font-medium" : "text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/30",
                    ]}
                  >
                    {active && <span class="absolute left-0 top-1/2 -translate-y-1/2 w-[2.5px] h-4 rounded-full bg-primary" />}
                    {item.title}
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ═══ MOBILE DRAWER ═══ -->
    <div id="mobile-drawer" class="lg:hidden fixed inset-0 z-50 hidden">
      <div id="drawer-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-72 bg-zinc-950 border-r border-zinc-800 overflow-y-auto">
        <div class="flex items-center justify-between px-4 h-14 border-b border-zinc-800">
          <span class="text-sm font-semibold text-zinc-200">Docs</span>
          <button id="drawer-close" class="h-8 w-8 flex items-center justify-center rounded-lg text-zinc-500 hover:text-zinc-200" aria-label="Close">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <nav class="px-3 py-5 space-y-4">
          {sidebar.map(group => (
            <div>
              <div class="px-3 mb-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-600">{group.label}</div>
              <div class="space-y-px">
                {group.items.map(item => {
                  const href = `/docs/${item.slug}/`;
                  const active = item.slug === currentSlug;
                  return (
                    <a href={href} class:list={[
                      "relative block rounded-md px-3 py-[6px] text-[13px] transition-colors",
                      active ? "text-zinc-100 bg-zinc-800/80 font-medium" : "text-zinc-500 hover:text-zinc-300",
                    ]}>
                      {active && <span class="absolute left-0 top-1/2 -translate-y-1/2 w-[2.5px] h-4 rounded-full bg-primary" />}
                      {item.title}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </nav>
      </aside>
    </div>

    <!-- ═══ CONTENT ═══ -->
    <div class="flex-1 min-w-0">
      <article class="max-w-3xl mx-auto px-6 sm:px-10 lg:px-16 py-12 lg:py-16">

        <!-- Mobile header -->
        <div class="lg:hidden flex items-center gap-3 mb-8">
          <button id="mobile-menu-btn" class="h-8 w-8 flex items-center justify-center rounded-lg border border-zinc-800 text-zinc-500 hover:text-zinc-200" aria-label="Menu">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
          </button>
          <nav class="text-xs text-zinc-600" aria-label="Breadcrumb">
            <a href="/docs/" class="hover:text-zinc-400">Docs</a>
            {entry.id.includes('/') && (
              <>
                <span class="mx-1.5">/</span>
                <span>{entry.id.split('/').slice(0, -1).map(p => p.replace(/-/g, ' ')).join(' / ')}</span>
              </>
            )}
            <span class="mx-1.5">/</span>
            <span class="text-zinc-400">{entry.data.title}</span>
          </nav>
        </div>

        <!-- Title -->
        <header class="mb-14">
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-zinc-50 leading-tight">{entry.data.title}</h1>
          {entry.data.description && (
            <p class="mt-4 text-lg text-zinc-500 leading-relaxed">{entry.data.description}</p>
          )}
        </header>

        <!-- Markdown body -->
        <div class="doc">
          <Content />
        </div>

        <!-- Prev / Next -->
        {(prev || next) && (
          <nav class="mt-20 pt-8 border-t border-zinc-800/50 grid grid-cols-1 sm:grid-cols-2 gap-4">
            {prev && (
              <a href={`/docs/${prev.id}/`} class="group rounded-xl border border-zinc-800/50 p-5 hover:border-zinc-700 hover:bg-zinc-900/30 transition-all">
                <span class="text-[10px] uppercase tracking-widest text-zinc-600 mb-1 block">Previous</span>
                <span class="text-sm font-medium text-zinc-400 group-hover:text-primary transition-colors">{prev.title}</span>
              </a>
            )}
            {next && (
              <a href={`/docs/${next.id}/`} class:list={[
                "group rounded-xl border border-zinc-800/50 p-5 hover:border-zinc-700 hover:bg-zinc-900/30 transition-all text-right",
                !prev && "sm:col-start-2",
              ]}>
                <span class="text-[10px] uppercase tracking-widest text-zinc-600 mb-1 block">Next</span>
                <span class="text-sm font-medium text-zinc-400 group-hover:text-primary transition-colors">{next.title}</span>
              </a>
            )}
          </nav>
        )}

        <div class="h-32"></div>
      </article>
    </div>
  </div>

  <script>
    // Progress bar
    const bar = document.getElementById('progress-bar');
    addEventListener('scroll', () => {
      if (!bar) return;
      const p = scrollY / (document.documentElement.scrollHeight - innerHeight);
      bar.style.transform = `scaleX(${Math.min(p, 1)})`;
    }, { passive: true });

    // Mobile drawer
    const open = () => document.getElementById('mobile-drawer')?.classList.remove('hidden');
    const close = () => document.getElementById('mobile-drawer')?.classList.add('hidden');
    document.getElementById('mobile-menu-btn')?.addEventListener('click', open);
    document.getElementById('drawer-close')?.addEventListener('click', close);
    document.getElementById('drawer-backdrop')?.addEventListener('click', close);
  </script>
</Layout>

<style>
  /* ═══════════════════════════════════════════
     DOC PROSE — Clean, spacious, readable
     ═══════════════════════════════════════════ */

  .doc {
    color: hsl(0 0% 82%);
    line-height: 1.85;
    font-size: 1rem;
  }

  /* Headings — bright, spaced, separated */
  .doc h2 {
    font-family: 'Outfit Variable', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: hsl(0 0% 95%);
    margin-top: 4rem;
    margin-bottom: 1.25rem;
    padding-top: 2rem;
    border-top: 1px solid hsl(240 3.7% 15.9%);
    scroll-margin-top: 5rem;
  }

  .doc h3 {
    font-family: 'Outfit Variable', system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: hsl(0 0% 90%);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 5rem;
  }

  /* Body text */
  .doc p {
    margin-bottom: 1.5rem;
  }

  .doc > *:first-child {
    margin-top: 0;
  }

  /* Links */
  .doc a {
    color: hsl(174 80% 56%);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: hsl(174 80% 46% / 0.3);
    transition: text-decoration-color 0.15s;
  }

  .doc a:hover {
    text-decoration-color: hsl(174 80% 46% / 0.8);
  }

  /* Lists */
  .doc ul, .doc ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .doc ul { list-style-type: disc; }
  .doc ol { list-style-type: decimal; }

  .doc li {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .doc li::marker {
    color: hsl(174 80% 46% / 0.5);
  }

  .doc ol li::marker {
    color: hsl(174 80% 46%);
    font-weight: 600;
  }

  /* Inline code */
  .doc :not(pre) > code {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.85em;
    background: hsl(240 3.7% 15.9% / 0.7);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: hsl(174 72% 70%);
  }

  /* Code blocks */
  .doc pre {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.85rem;
    line-height: 1.7;
    background: hsl(240 10% 2%);
    border: 1px solid hsl(240 3.7% 15.9% / 0.5);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0 2rem;
  }

  .doc pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: hsl(0 0% 80%);
  }

  /* Blockquotes */
  .doc blockquote {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid hsl(174 80% 46% / 0.4);
    background: hsl(240 3.7% 15.9% / 0.25);
    border-radius: 0 8px 8px 0;
    color: hsl(0 0% 68%);
  }

  .doc blockquote p:last-child {
    margin-bottom: 0;
  }

  .doc blockquote strong {
    color: hsl(0 0% 85%);
  }

  /* Tables */
  .doc table {
    width: 100%;
    margin: 1.5rem 0 2rem;
    font-size: 0.875rem;
    border: 1px solid hsl(240 3.7% 15.9% / 0.5);
    border-radius: 8px;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
  }

  .doc th {
    text-align: left;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: hsl(0 0% 65%);
    padding: 0.75rem 1rem;
    background: hsl(240 3.7% 15.9% / 0.4);
    border-bottom: 1px solid hsl(240 3.7% 15.9% / 0.5);
  }

  .doc td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid hsl(240 3.7% 15.9% / 0.2);
    color: hsl(0 0% 78%);
  }

  .doc tr:last-child td {
    border-bottom: none;
  }

  .doc tr:hover td {
    background: hsl(240 3.7% 15.9% / 0.15);
  }

  /* Horizontal rule */
  .doc hr {
    border: none;
    height: 1px;
    background: hsl(240 3.7% 15.9% / 0.5);
    margin: 3rem 0;
  }

  /* Images */
  .doc img {
    border-radius: 10px;
    border: 1px solid hsl(240 3.7% 15.9% / 0.4);
    margin: 2rem 0;
  }

  /* Strong */
  .doc strong {
    color: hsl(0 0% 92%);
    font-weight: 600;
  }

  /* Callouts */
  .doc :global(.callout) {
    border-radius: 8px;
    border: 1px solid hsl(240 3.7% 15.9% / 0.4);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .doc :global(.callout-info) { border-left: 3px solid hsl(217 91% 60%); background: hsl(217 91% 60% / 0.08); }
  .doc :global(.callout-warning) { border-left: 3px solid hsl(38 92% 50%); background: hsl(38 92% 50% / 0.08); }
  .doc :global(.callout-danger) { border-left: 3px solid hsl(0 84% 60%); background: hsl(0 84% 60% / 0.08); }
  .doc :global(.callout-success) { border-left: 3px solid hsl(160 84% 39%); background: hsl(160 84% 39% / 0.08); }
</style>
